# Copy to .env.local for local dev, and set the same vars in your Vercel project.
# See DEPLOY.md for the full runbook.

# ---- Public (safe to expose to the browser; must be NEXT_PUBLIC_*) ----
# The app's canonical URL. On Vercel, set this to your deployment URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# One of: coston2 | songbird | flare
NEXT_PUBLIC_FLARE_NETWORK="coston2"

# Supabase Auth. Enable the Google provider in Supabase and add your Google
# OAuth credentials there. The legacy ANON key name is also supported.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---- Server-only (never exposed to the client) ----
# Postgres (Supabase). Either variable works; the app prefers DATABASE_URL.
# Use the Supabase CONNECTION POOLER URL for serverless (Vercel). The DB client
# sets prepare:false so it's pooler-safe. Schema auto-creates on first request.
DATABASE_URL=""
# POSTGRES_URL=""

# Which enclave backs key custody:
#   simulated = in-process software enclave (default; what the hosted demo runs)
#   coston2   = real Flare Confidential Compute extension (requires FCE_PROXY_URL)
ENCLAVE_MODE="simulated"
# Only when ENCLAVE_MODE=coston2 — the FCE ext-proxy endpoint the app calls.
FCE_PROXY_URL=""

# Optional: override the Coston2 RPC used for on-chain condition checks
# (wallet / token / NFT). Defaults to the public Coston2 endpoint.
FLARE_RPC_URL=""
